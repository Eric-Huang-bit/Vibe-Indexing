{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "vibe-indexing: --help",
      "type": "debugpy",
      "request": "launch",
      "module": "vibe_indexing",
      "args": ["--help"],
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "pytest: all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "tests"],
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    }
  ]
}
